---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar';
import Footer from '../components/Footer';
import { Quote } from 'lucide-react';
---

<Layout>
	<Navbar client:load />
	<main class="pt-32 pb-24 px-6 md:px-12 bg-white">
		<div class="max-w-7xl mx-auto space-y-32">
			<header class="max-w-4xl space-y-12">
				<h1 class="text-6xl md:text-9xl font-serif tracking-tight leading-[0.9]">
					For the <span class="italic">midnight owls</span> who brew.
				</h1>
				<p class="text-[#1a1a1a]/60 text-xl md:text-3xl leading-relaxed font-light">
					Midnight Pulse was born out of the quiet stillness between 2 AM and sunrise. 
					We saw a community of creators, coders, and dreamers who found their focus 
					in the silence, but needed a different kind of fuel.
				</p>
			</header>

			<div class="grid grid-cols-1 md:grid-cols-2 gap-24 items-center py-24 border-y border-[#1a1a1a]/5">
				<div class="space-y-10">
					<h3 class="text-4xl font-serif tracking-tight italic">Our Roastery Ethos</h3>
					<div class="space-y-6 text-[#1a1a1a]/60 text-lg leading-relaxed font-light">
						<p>
							Based in the heart of Mumbai, our roastery is where the science of heat meets the art of flavor. 
							We roast in small, precision-controlled batches, ensuring every bean reaches its peak potential.
						</p>
						<p>
							Sustainability isn't just a buzzword for us. We work directly with estates in Chickmagalur and 
							Wayanad, ensuring fair wages and ethical practices at every step of the supply chain.
						</p>
					</div>
				</div>
				<div class="aspect-[4/5] overflow-hidden rounded-[2.5rem] bg-[#e2d9c8]/20 relative shadow-2xl">
					<img src="https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?q=80&w=2070&auto=format&fit=crop" class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-1000" alt="Roastery" />
					<div class="absolute inset-0 bg-gradient-to-t from-[#1a1a1a]/60 to-transparent" />
					<div class="absolute bottom-12 left-12 right-12 text-white">
						<p class="text-xs font-bold tracking-[0.3em] uppercase opacity-60 mb-4">The Batch #102</p>
						<h4 class="text-3xl font-serif italic">The alchemy of the night.</h4>
					</div>
				</div>
			</div>

			<div class="max-w-3xl mx-auto text-center space-y-12 py-24">
				<Quote size={48} className="mx-auto text-[#e2d9c8]" />
				<h3 className="text-4xl md:text-6xl font-serif tracking-tight leading-tight italic">
					"We don't just roast coffee. We craft the companion for your best work."
				</h3>
				<p class="text-xs font-bold tracking-[0.3em] uppercase opacity-40">Arjun, Head Roaster</p>
			</div>
		</div>
	</main>
	<Footer client:visible />
</Layout>
