---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar';
import Footer from '../components/Footer';
import { Coffee, Droplets, Thermometer, Timer } from 'lucide-react';
---

<Layout>
	<Navbar client:load />
	<main class="pt-32 pb-24 px-6 md:px-12 bg-white">
		<div class="max-w-7xl mx-auto space-y-32">
			<header class="max-w-4xl space-y-12">
				<h1 class="text-6xl md:text-9xl font-serif tracking-tight leading-[0.9]">
					The <span class="italic">Art</span> of Extraction.
				</h1>
				<p class="text-[#1a1a1a]/60 text-xl md:text-3xl leading-relaxed font-light">
					A guide to brewing the perfect cup, whether you're at the bar or at your desk. 
					Master the craft and fuel your focus.
				</p>
			</header>

			<div class="grid grid-cols-1 md:grid-cols-2 gap-16 py-12">
				<div class="p-12 bg-[#faf9f6] rounded-[2.5rem] space-y-8 group hover:shadow-xl hover:shadow-[#1a1a1a]/5 transition-all">
					<div class="w-16 h-16 bg-white rounded-3xl flex items-center justify-center text-[#1a1a1a] shadow-sm group-hover:bg-[#1a1a1a] group-hover:text-white transition-colors duration-500">
						<Coffee size={32} />
					</div>
					<h3 class="text-4xl font-serif tracking-tight leading-tight italic">The Midnight V60</h3>
					<div class="space-y-4">
						<div class="flex items-center space-x-4 text-xs font-bold tracking-[0.2em] uppercase opacity-40">
							<div class="flex items-center space-x-1"><Timer size={14} /> <span>3:00 min</span></div>
							<div class="flex items-center space-x-1"><Thermometer size={14} /> <span>92°C</span></div>
							<div class="flex items-center space-x-1"><Droplets size={14} /> <span>250ml</span></div>
						</div>
						<p class="text-[#1a1a1a]/60 leading-relaxed font-light">
							The cleanest way to experience the subtle floral notes of our Ethiopian single origins. 
							Perfect for clarity and sustained focus.
						</p>
					</div>
					<button class="w-full py-4 border border-[#1a1a1a] rounded-full text-sm font-medium hover:bg-[#1a1a1a] hover:text-white transition-colors">
						View Guide
					</button>
				</div>

				<div class="p-12 bg-[#faf9f6] rounded-[2.5rem] space-y-8 group hover:shadow-xl hover:shadow-[#1a1a1a]/5 transition-all">
					<div class="w-16 h-16 bg-white rounded-3xl flex items-center justify-center text-[#1a1a1a] shadow-sm group-hover:bg-[#1a1a1a] group-hover:text-white transition-colors duration-500">
						<Coffee size={32} />
					</div>
					<h3 class="text-4xl font-serif tracking-tight leading-tight italic">The Pulse Espresso</h3>
					<div class="space-y-4">
						<div class="flex items-center space-x-4 text-xs font-bold tracking-[0.2em] uppercase opacity-40">
							<div class="flex items-center space-x-1"><Timer size={14} /> <span>28 sec</span></div>
							<div class="flex items-center space-x-1"><Thermometer size={14} /> <span>93.5°C</span></div>
							<div class="flex items-center space-x-1"><Droplets size={14} /> <span>36ml</span></div>
						</div>
						<p class="text-[#1a1a1a]/60 leading-relaxed font-light">
							The intense, concentrated fuel of our Electric City blend. 
							A morning ritual to kickstart your deep-work sessions.
						</p>
					</div>
					<button class="w-full py-4 border border-[#1a1a1a] rounded-full text-sm font-medium hover:bg-[#1a1a1a] hover:text-white transition-colors">
						View Guide
					</button>
				</div>
			</div>
		</div>
	</main>
	<Footer client:visible />
</Layout>
